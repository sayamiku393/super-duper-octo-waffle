class EditItemWindow(QMainWindow):
    def __init__(self, parent=None):
        super().__init__()
        uic.loadUi('UI\product_redact.ui', self)
        self.submit.clicked.connect(self.collect_data)
        self.cansel.clicked.connect(self.back)
        self.parent = parent

        with engine.begin() as conn:
            suppliers = conn.execute(text("select distinct supplier from itemz")).fetchall()
            manufactrs = conn.execute(text("select distinct manufactr from itemz")).fetchall()
        for s in suppliers:
            self.supplier.addItem(s[0])
        for m in manufactrs:
            self.manufactr.addItem(m[0])

    def back(self):
        self.close()
        self.parent.show()

    def collect_data(self):
        item_dict = {
            "art": self.art.text(),
            "model": self.model.text(),
            "measure": self.measure.text(),
            "price": self.price.text(),
            "supplier": self.supplier.currentText(),
            "manufactr": self.manufactr.currentText(),
            "category": self.category.text(),
            "discount": self.discount.text(),
            "amount": self.amount.text(),
            "descr": self.descr.toPlainText(),
            "photopath": f"{self.photopath.text()}" if self.photopath.text() is not None else f"C:\\Users\\Neco-Tyan\\Desktop\\import\\pics\\picture.png"
        }
        with engine.begin() as conn:
            conn.execute(insert(items), item_dict)
        self.close()


